						</a>
						<button type="submit" form="saveForm" class="px-3 py-1.5 text-xs font-bold text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition shadow-sm shadow-primary-500/10 flex items-center gap-1.5">
							<i class="fa-solid fa-floppy-disk"></i>
							<span>등록</span>
						</button>
					</div>
				</header>

				<!-- Scrollable Content Body -->
				<main class="flex-1 overflow-y-auto p-6 space-y-6">
					
					<!-- Content Header Title Card -->
					<div class="bg-white rounded-2xl p-6 border border-slate-200 flex items-center justify-between shadow-sm">
						<div>
							<h2 class="text-xl font-bold text-slate-800 flex items-center gap-3">
								<span>자료 통합 등록</span>
								<span class="text-xs bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full font-medium border border-blue-100">운영관리</span>
							</h2>
							<p class="text-sm text-slate-400 mt-1">새로운 통합 운영관리 자료를 등록합니다. 필수 입력 항목(*)을 빠짐없이 기입해주세요.</p>
						</div>
					</div>

					<!-- REGISTER FORM -->
					<form id="saveForm" class="space-y-6">
						<!-- Hidden Inputs -->
						<input type="hidden" name="dataSclsfMltiplIdVl" id="dataSclsfMltiplIdVl" value="0" />
						<input type="hidden" name="dataSrcCd" id="dataSrcCd" value="1" />
						<input type="hidden" name="dataPstgSttsCd" value="1" />
						<input type="hidden" name="pstgPrdCd" value="1" />

						<!-- Card 1: 자료 기초 설정 -->
						<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
							<div class="px-6 py-4 bg-slate-50/50 border-b border-slate-100">
								<h3 class="text-sm font-bold text-slate-700 flex items-center gap-2">
									<i class="fa-solid fa-gear text-slate-400"></i>
									<span>자료 기초 설정 (공개범위, 제약사항 등)</span>
								</h3>
							</div>
							<div class="p-6 space-y-6">
								<!-- 공개범위 설정 -->
								<div class="flex flex-col lg:flex-row gap-2 lg:items-start">
									<label class="text-xs font-bold text-slate-600 w-44 flex-shrink-0 pt-2">
