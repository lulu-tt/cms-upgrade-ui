									<div class="flex-1">
										<input type="text" name="regDept" id="regDept" placeholder="작성부서명을 입력해주세요." class="w-full max-w-[300px] border border-slate-200 rounded-lg px-3.5 py-2 text-xs text-slate-600 focus:outline-none focus:ring-1 focus:ring-primary-500 bg-white">
									</div>
