		<!-- Scripts -->
		<script src="js/ollama-integration.js"></script>
		<script src="js/file-analyzer.js"></script>
		<script>
			// ========== 첨부파일 드래그 앤 드롭 기능 ==========
			function initFileUpload() {
				const fileInput = document.querySelector('input[type="file"][multiple]');
				if (!fileInput) {
					console.warn('파일 입력 요소를 찾을 수 없습니다');
					return;
				}

				// 드래그 앤 드롭 영역 (border-dashed 클래스를 가진 div)
				const dropZone = fileInput.closest('div[class*="border-dashed"]');
				if (!dropZone) {
					console.warn('드래그 앤 드롭 영역을 찾을 수 없습니다');
					return;
				}

				console.log('✅ 파일 업로드 초기화 완료', { fileInput, dropZone });

				// 클릭하여 파일 선택
				dropZone.addEventListener('click', function(e) {
					if (e.target.closest('button')) return;
					fileInput.click();
				});

				// 드래그 오버
				dropZone.addEventListener('dragover', function(e) {
					e.preventDefault();
					e.stopPropagation();
					dropZone.style.borderColor = '#2563eb';
					dropZone.style.backgroundColor = '#f0f5ff';
				});

				// 드래그 리브
				dropZone.addEventListener('dragleave', function(e) {
					e.preventDefault();
					e.stopPropagation();
					dropZone.style.borderColor = '';
					dropZone.style.backgroundColor = '';
				});

				// 드롭
				dropZone.addEventListener('drop', function(e) {
					e.preventDefault();
					e.stopPropagation();
					dropZone.style.borderColor = '';
					dropZone.style.backgroundColor = '';

					if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
						fileInput.files = e.dataTransfer.files;
						fileInput.dispatchEvent(new Event('change', { bubbles: true }));
						console.log('✅ 파일 드롭 완료:', e.dataTransfer.files.length, '개');
					}
				});

				// 파일 선택 변경 이벤트
				fileInput.addEventListener('change', function() {
					console.log('✅ 파일 선택됨:', this.files.length, '개');

					// 기존 파일 목록 제거
					const existingList = dropZone.parentElement.querySelector('[id="file-list"]');
					if (existingList) existingList.remove();

					if (this.files.length === 0) return;

					// 새 파일 목록 생성
					const fileList = document.createElement('div');
					fileList.id = 'file-list';
					fileList.className = 'mt-3 space-y-2';

					Array.from(this.files).forEach((file) => {
						const fileItem = document.createElement('div');
						fileItem.className = 'flex items-center justify-between p-3 bg-blue-50 rounded-lg border border-blue-200 text-xs';

						const ext = file.name.split('.').pop().toLowerCase();
						let iconClass = 'fa-file';

						if (['jpg', 'jpeg', 'png', 'gif', 'bmp', 'svg'].includes(ext)) {
							iconClass = 'fa-image';
						} else if (ext === 'pdf') {
							iconClass = 'fa-file-pdf';
						} else if (ext === 'txt') {
							iconClass = 'fa-file-lines';
						}

						const fileSize = (file.size / 1024 / 1024).toFixed(2);

						fileItem.innerHTML = `
							<div class="flex items-center gap-3 flex-1">
								<i class="fa-solid ${iconClass} text-blue-500"></i>
								<div class="flex-1">
									<p class="font-semibold text-slate-700">${file.name}</p>
									<p class="text-[10px] text-slate-500">${fileSize} MB</p>
								</div>
							</div>
							<button type="button" class="ml-2 text-slate-400 hover:text-red-600 transition p-1" onclick="this.parentElement.remove(); return false;">
								<i class="fa-solid fa-xmark"></i>
							</button>
						`;
						fileList.appendChild(fileItem);
					});

					// 파일 목록 추가
					dropZone.parentElement.appendChild(fileList);
				});
			}

			// 페이지 로드 시 초기화
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initFileUpload);
			} else {
				initFileUpload();
			}

			// 사이드바 접기/펼치기
			document.addEventListener('DOMContentLoaded', function() {
				const sidebar = document.getElementById('sidebar');
				const sidebarToggle = document.getElementById('sidebar-toggle');
				if (sidebar && sidebarToggle) {
					const toggleSidebarIcon = sidebarToggle.querySelector('i');
					sidebarToggle.addEventListener('click', function() {
						sidebar.classList.toggle('collapsed');
						if (sidebar.classList.contains('collapsed')) {
							toggleSidebarIcon.classList.remove('fa-angles-left');
							toggleSidebarIcon.classList.add('fa-angles-right');
							sidebarToggle.setAttribute('title', '메뉴 펼치기');
						} else {
							toggleSidebarIcon.classList.remove('fa-angles-right');
							toggleSidebarIcon.classList.add('fa-angles-left');
							sidebarToggle.setAttribute('title', '메뉴 접기');
						}
					});
				}
			});
		</script>
	</body>
</html>
