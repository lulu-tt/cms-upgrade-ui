											<input type="checkbox" id="tag_danchegyo" name="searchMultiIemArrayHashTag" value="단체교섭" class="hidden">

											<button type="button" onclick="toggleTag(this, 'tag_insanomu')" class="px-3.5 py-1.5 text-xs rounded-full border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition font-medium">인사노무관리</button>
											<input type="checkbox" id="tag_insanomu" name="searchMultiIemArrayHashTag" value="인사노무관리" class="hidden">

