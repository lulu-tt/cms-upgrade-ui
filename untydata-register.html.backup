								</h3>
							</div>
							<div class="p-6 space-y-4">
								<!-- Tab Menu -->
								<div class="flex border-b border-slate-200 text-xs font-bold">
									<button type="button" id="tab-code" class="px-5 py-2.5 border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition" onclick="switchEditorTab('code')">코드(CodeMirror)로 수정</button>
									<button type="button" id="tab-editor" class="px-5 py-2.5 border-b-2 border-primary-500 text-primary-600 transition" onclick="switchEditorTab('editor')">웹 에디터(CKEditor)로 수정</button>
								</div>
								
								<!-- Editor Contents -->
								<div>
									<!-- Code Editor (Hidden by default) -->
									<div id="editor-code-container" class="hidden">
										<textarea id="codeText" class="w-full h-80 font-mono text-xs p-4 bg-slate-900 text-slate-300 rounded-2xl border border-slate-800 focus:outline-none focus:ring-1 focus:ring-primary-500" placeholder="<!-- HTML 코드를 작성하세요 -->"></textarea>
									</div>

									<!-- Web Editor Mockup (Visible by default) -->
									<div id="editor-web-container" class="border border-slate-200 rounded-2xl overflow-hidden shadow-inner">
										<!-- Editor Toolbar -->
										<div class="bg-slate-50 border-b border-slate-200 p-2 flex flex-wrap gap-1.5 items-center text-slate-500 text-xs">
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="되돌리기"><i class="fa-solid fa-rotate-left"></i></button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="다시실행"><i class="fa-solid fa-rotate-right"></i></button>
											<div class="h-4 w-px bg-slate-300 mx-1"></div>
											<select class="bg-white border border-slate-200 rounded px-1.5 py-0.5 text-[11px] focus:outline-none">
												<option>본문</option>
												<option>제목 1</option>
												<option>제목 2</option>
												<option>제목 3</option>
											</select>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center font-bold" title="굵게">B</button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center italic" title="기울임">I</button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center underline" title="밑줄">U</button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center line-through" title="취소선">S</button>
											<div class="h-4 w-px bg-slate-300 mx-1"></div>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="좌측정렬"><i class="fa-solid fa-align-left"></i></button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="가운데정렬"><i class="fa-solid fa-align-center"></i></button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="우측정렬"><i class="fa-solid fa-align-right"></i></button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="양끝정렬"><i class="fa-solid fa-align-justify"></i></button>
											<div class="h-4 w-px bg-slate-300 mx-1"></div>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="번호매기기"><i class="fa-solid fa-list-ol"></i></button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="글머리기호"><i class="fa-solid fa-list-ul"></i></button>
											<div class="h-4 w-px bg-slate-300 mx-1"></div>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="링크삽입"><i class="fa-solid fa-link"></i></button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="이미지삽입"><i class="fa-solid fa-image"></i></button>
											<button type="button" class="w-7 h-7 hover:bg-slate-200 rounded flex items-center justify-center" title="표삽입"><i class="fa-solid fa-table"></i></button>
											<div class="h-4 w-px bg-slate-300 mx-1 flex-1"></div>
											<div class="flex items-center gap-1.5 text-[10px] text-slate-400">
												<i class="fa-solid fa-display"></i>
												<span>기기별 미리보기</span>
												<i class="fa-solid fa-chevron-down text-[8px]"></i>
											</div>
										</div>
										<!-- Content editable editor body -->
										<div class="min-h-[300px] p-6 focus:outline-none bg-white text-sm" contenteditable="true">
											<p class="text-slate-400">여기에 자료설명을 입력해 주세요...</p>
