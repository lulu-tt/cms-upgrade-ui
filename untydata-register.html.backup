						<!-- Card 5: 메타정보 -->
						<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
							<div class="px-6 py-4 bg-slate-50/50 border-b border-slate-100">
								<h3 class="text-sm font-bold text-slate-700 flex items-center gap-2">
									<i class="fa-solid fa-tags text-slate-400"></i>
									<span>메타정보</span>
								</h3>
							</div>
							<div class="p-6 space-y-6">
								<!-- 자료주제(테마) -->
								<div class="flex flex-col lg:flex-row gap-2 lg:items-start">
									<span class="text-xs font-bold text-slate-600 w-44 flex-shrink-0 pt-2">
										자료주제(테마) <span class="text-red-500 font-bold">*</span>
									</span>
									<div class="flex-1">
										<div class="flex flex-wrap gap-2.5 max-w-5xl">
											<!-- 태그 리스트 (button 및 hidden input 구조로 변경하여 더블 클릭 및 페이지 에러 예방) -->
											<button type="button" onclick="toggleTag(this, 'tag_nosagwan')" class="px-3.5 py-1.5 text-xs rounded-full border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition font-medium">노사관계</button>
