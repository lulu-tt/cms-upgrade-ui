			<!-- MAIN CONTENT AREA -->
			<div class="flex-1 flex flex-col overflow-hidden">
				
				<!-- Header (Topbar) -->
				<header class="h-14 bg-white border-b border-slate-200 flex items-center justify-between px-6 z-10">
					<div class="flex items-center gap-4">
						<button class="w-8 h-8 rounded-lg hover:bg-slate-100 flex items-center justify-center text-slate-500 hover:text-slate-800 transition" onclick="history.back(); return false;">
							<i class="fa-solid fa-arrow-left"></i>
						</button>
						<div class="flex flex-col">
							<!-- Breadcrumb -->
							<ol class="flex items-center gap-1.5 text-xs text-slate-400 font-medium">
								<li>사이트별 운영관리</li>
								<li><i class="fa-solid fa-chevron-right text-[8px]"></i></li>
								<li>한국고용정보원-국문</li>
