						</div>

						<!-- Form Action Buttons -->
						<div class="flex items-center justify-between">
							<a href="untydata-list.html" class="px-4 py-2 text-xs font-bold text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 rounded-lg transition flex items-center gap-1.5 shadow-sm">
								<i class="fa-solid fa-chevron-left text-[10px]"></i>
								<span>목록</span>
							</a>
							
							<div class="flex gap-2">
								<button type="button" id="ai-agent-toggle" class="px-6 py-2.5 text-xs font-bold text-purple-600 bg-purple-50 hover:bg-purple-100 border border-purple-200 rounded-lg transition flex items-center gap-1.5">
									<i class="fa-solid fa-wand-magic-sparkles"></i>
									<span>AI 에이전트</span>
								</button>
								<a href="untydata-list.html" class="px-6 py-2.5 text-xs font-bold text-slate-500 bg-white border border-slate-200 hover:bg-slate-50 rounded-lg transition">
									취소
								</a>
								<button type="submit" class="px-6 py-2.5 text-xs font-bold text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition shadow-md shadow-primary-500/10 flex items-center gap-1.5">
									<i class="fa-solid fa-floppy-disk"></i>
									<span>등록</span>
								</button>
							</div>
						</div>
					</form>
				</main>

				<!-- Footer Bar -->
				<footer class="h-9 bg-white border-t border-slate-200 flex items-center justify-between px-6 text-[10px] text-slate-400 font-medium z-10 flex-shrink-0">
					<span>NEIBIS 시스템 &copy; 2026. All rights reserved.</span>
					<span>v2.4.1 · 행정서비스망</span>
				</footer>
			</div>
		</div>

		<script>
			// 태그(자료주제) 온/오프 토글 함수
			function toggleTag(btn, inputId) {
				const input = document.getElementById(inputId);
				if (!input) return;
				
				input.checked = !input.checked;
				
				if (input.checked) {
					btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-200', 'hover:bg-slate-50');
					btn.classList.add('bg-primary-50', 'text-primary-600', 'border-primary-500');
				} else {
					btn.classList.add('bg-white', 'text-slate-600', 'border-slate-200', 'hover:bg-slate-50');
					btn.classList.remove('bg-primary-50', 'text-primary-600', 'border-primary-500');
				}
			}

			// 1. 공개범위 설정 변경 시 현황에 반영
			function updateScopeStatus() {
				const container = document.getElementById('dataRlsScopeCdTextArea');
				container.innerHTML = '';
				
				const scopes = [
					{ id: 'insdDataRlsScopeCd_1', name: '전체공개', val: 1 },
					{ id: 'insdDataRlsScopeCd_2', name: '제한공개(부서기반)', val: 2 },
					{ id: 'insdDataRlsScopeCd_3', name: '제한공개(직원기반)', val: 3 }
				];
				
				let checkedCount = 0;
				scopes.forEach(scope => {
					const el = document.getElementById(scope.id);
					if (el && el.checked) {
						checkedCount++;
						const chip = document.createElement('span');
						chip.className = 'inline-flex items-center gap-2 px-3 py-1.5 text-xs font-semibold text-primary-600 bg-primary-50 border border-primary-100 rounded-xl';
						chip.id = `scope-status-item-${scope.val}`;
						chip.innerHTML = `
							<span>${scope.val === 1 ? '모두 공개' : scope.name}</span>
							<button type="button" class="text-slate-400 hover:text-red-500 transition" onclick="removeScope(${scope.val})" title="삭제">
								<i class="fa-solid fa-xmark text-[10px]"></i>
							</button>
						`;
						container.appendChild(chip);
					}
				});
				
				if (checkedCount === 0) {
					container.innerHTML = '<span class="text-xs text-slate-400">선택된 공개범위가 없습니다.</span>';
				}
			}

			function removeScope(val) {
				const el = document.getElementById(`insdDataRlsScopeCd_${val}`);
				if (el) {
					el.checked = false;
					updateScopeStatus();
				}
			}

			// 2. 대분류 변경 시 중분류/소분류 토글
			function handleCategoryChange() {
				const lclsf = document.getElementById('dataLclsfCd').value;
				const mclsfArea = document.getElementById('dataMclsfCdArea');
				const mclsfSelect = document.getElementById('dataMclsfCd');
				const sclsfArea = document.getElementById('dataSclsfMltiplCdArea');

				// Reset
				mclsfSelect.innerHTML = '<option value="">중분류를 선택해주세요</option>';
				sclsfArea.innerHTML = '';
				mclsfArea.classList.add('hidden');
				sclsfArea.classList.add('hidden');

				if (!lclsf) return;

				mclsfArea.classList.remove('hidden');

				// 대분류에 따라 임시 중분류 생성 (데모 구현)
				if (lclsf === '1') { // 교육자료
					const options = [
						{ val: '11', text: '기초노동법 교육' },
						{ val: '12', text: '인사노무 실무' },
						{ val: '13', text: '갈등 예방 교육' }
					];
					options.forEach(opt => {
						const o = document.createElement('option');
						o.value = opt.val;
						o.textContent = opt.text;
						mclsfSelect.appendChild(o);
					});
				} else if (lclsf === '3') { // 연구자료
					const options = [
						{ val: '31', text: '정책 연구보고서' },
						{ val: '32', text: '동향 및 통계' }
					];
					options.forEach(opt => {
						const o = document.createElement('option');
						o.value = opt.val;
						o.textContent = opt.text;
						mclsfSelect.appendChild(o);
					});
				} else if (lclsf === '4') { // 홍보자료
					const options = [
						{ val: '41', text: '리플릿/브로슈어' },
						{ val: '42', text: '홍보 영상' }
					];
					options.forEach(opt => {
						const o = document.createElement('option');
						o.value = opt.val;
						o.textContent = opt.text;
						mclsfSelect.appendChild(o);
					});
				}

				// 중분류 선택에 따른 소분류 체크박스 표시 동작 설정
				mclsfSelect.onchange = function() {
					const mval = this.value;
					sclsfArea.innerHTML = '';
					
					if (mval) {
						sclsfArea.classList.remove('hidden');
						// 임시 소분류 추가
						const subs = ['기초 공통', '심화 트랙', '사례 분석', '일반 실무'];
						subs.forEach((sub, idx) => {
							const label = document.createElement('label');
							label.className = 'flex items-center gap-2 cursor-pointer text-xs text-slate-600 font-medium';
							label.innerHTML = `
								<input type="checkbox" name="dataSclsfMltiplCd" value="${mval}_${idx+1}" class="w-4 h-4 text-primary-600 border-slate-300 rounded focus:ring-primary-500">
								<span>${sub}</span>
							`;
							sclsfArea.appendChild(label);
						});
					} else {
						sclsfArea.classList.add('hidden');
					}
				};
			}

			// 3. 대상 전체 체크/해제
			function toggleAllTargets(master) {
				const chks = document.querySelectorAll('.target-chk');
				chks.forEach(chk => {
					chk.checked = master.checked;
				});
			}

			// 4. 자료유형 라디오 선택 시 토글
			function handleDataTypeChange(type) {
				const urlArea = document.getElementById('urlAddrArea');
				const movieArea = document.getElementById('movieArea');

				urlArea.classList.add('hidden');
				movieArea.classList.add('hidden');

				if (type === 2 || type === 3) {
					urlArea.classList.remove('hidden');
				} else if (type === 4) {
					movieArea.classList.remove('hidden');
				}
			}

			// 5. 썸네일 여부 라디오 선택 시 토글
			function handleThmbChange(val) {
				const thmbArea = document.getElementById('thmbArea');
				if (val === 'Y') {
					thmbArea.classList.remove('hidden');
				} else {
					thmbArea.classList.add('hidden');
				}
			}

			// 6. 에디터 탭 스위칭 스크립트
			function switchEditorTab(mode) {
				const btnCode = document.getElementById('tab-code');
				const btnEditor = document.getElementById('		<!-- AI AGENT SLIDE PANEL -->
