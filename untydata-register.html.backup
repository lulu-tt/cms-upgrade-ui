											<input type="checkbox" id="tag_gonggong" name="searchMultiIemArrayHashTag" value="공공기관" class="hidden">

											<button type="button" onclick="toggleTag(this, 'tag_cheongso')" class="px-3.5 py-1.5 text-xs rounded-full border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition font-medium">청소년/청년</button>
											<input type="checkbox" id="tag_cheongso" name="searchMultiIemArrayHashTag" value="청소년/청년" class="hidden">

											<button type="button" onclick="toggleTag(this, 'tag_gangsa')" class="px-3.5 py-1.5 text-xs rounded-full border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition font-medium">강사용성</button>
											<input type="checkbox" id="tag_gangsa" name="searchMultiIemArrayHashTag" value="강사용성" class="hidden">

											<button type="button" onclick="toggleTag(this, 'tag_online')" class="px-3.5 py-1.5 text-xs rounded-full border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition font-medium">온라인교육</button>
											<input type="checkbox" id="tag_online" name="searchMultiIemArrayHashTag" value="온라인교육" class="hidden">

											<button type="button" onclick="toggleTag(this, 'tag_sarye')" class="px-3.5 py-1.5 text-xs rounded-full border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition font-medium">사례해설</button>
											<input type="checkbox" id="tag_sarye" name="searchMultiIemArrayHashTag" value="사례해설" class="hidden">

											<button type="button" onclick="toggleTag(this, 'tag_goyong')" class="px-3.5 py-1.5 text-xs rounded-full border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition font-medium">고용</button>
											<input type="checkbox" id="tag_goyong" name="searchMultiIemArrayHashTag" value="고용" class="hidden">
