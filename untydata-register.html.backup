		<meta name="format-detection" content="telephone=no" />
		<title id="neibisTopTitle">사이트별 운영관리 | 한국고용정보원-국문 | 테스트 메뉴 | 자료 통합 관리(등록)</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
		
		<!-- FontAwesome Icons -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
		
		<!-- Tailwind CSS -->
		<script src="https://cdn.tailwindcss.com"></script>
		<script>
			tailwind.config = {
				theme: {
					extend: {
						fontFamily: {
							sans: ['Inter', 'Noto Sans KR', 'sans-serif'],
						},
						colors: {
							primary: {
								50: '#f0f5ff',
								100: '#e0ebff',
								500: '#2563eb',
								600: '#1d4ed8',
								700: '#1e40af',
							},
							sidebar: {
								bg: '#ffffff',
								hover: '#f3f4f6',
								active: '#eff6ff',
								text: '#374151',
								textMuted: '#9ca3af',
								border: '#e5e7eb',
							}
						}
					}
				}
			}
		</script>
		
		<style>
			body {
				font-family: 'Inter', 'Noto Sans KR', sans-serif;
				background-color: #f8fafc;
			}
			/* Custom scrollbar */
			::-webkit-scrollbar {
				width: 6px;
				height: 6px;
			}
			::-webkit-scrollbar-track {
				background: #f1f5f9;
			}
			::-webkit-scrollbar-thumb {
				background: #cbd5e1;
				border-radius: 3px;
			}
			::-webkit-scrollbar-thumb:hover {
				background: #94a3b8;
			}

			/* Sidebar Collapsed State Styles */
			#sidebar.collapsed {
				width: 4rem; /* w-16 */
			}
			#sidebar.collapsed .logo-text,
			#sidebar.collapsed .toolbar button:not(#sidebar-toggle),
			#sidebar.collapsed hr,
			#sidebar.collapsed .px-3.mb-2,
			#sidebar.collapsed span,
			#sidebar.collapsed p,
			#sidebar.collapsed select,
			#sidebar.collapsed input,
			#sidebar.collapsed button:not(#sidebar-toggle),
			#sidebar.collapsed details ul,
			#sidebar.collapsed ul ul,
			#sidebar.collapsed details summary i.fa-chevron-down,
			#sidebar.collapsed .flex-1.overflow-y-auto > div:first-child, /* 즐겨찾기 영역 */
			#sidebar.collapsed .flex-1.overflow-y-auto > div:nth-child(3) > div:first-child { /* 메뉴 탐색 타이틀 */
				display: none !important;
			}
			#sidebar.collapsed .sidebar-header {
				justify-content: center;
				padding: 1.25rem 0.5rem;
			}
			#sidebar.collapsed .sidebar-header a {
				justify-content: center;
			}
			#sidebar.collapsed nav a, 
			#sidebar.collapsed nav summary,
			#sidebar.collapsed .flex-1.overflow-y-auto a,
			#sidebar.collapsed .flex-1.overflow-y-auto summary {
				justify-content: center;
				padding-left: 0;
				padding-right: 0;
			}
			#sidebar.collapsed .flex-1.overflow-y-auto li a i {
				margin-right: 0 !important;
			}
			#sidebar.collapsed div.p-4.border-t {
				padding: 1rem 0.5rem;
				justify-content: center;
			}
			#sidebar.collapsed div.p-4.border-t .flex {
				justify-content: center;
			}
		</style>
	</head>
