											<input type="checkbox" id="tag_platform" name="searchMultiIemArrayHashTag" value="플랫폼노동" class="hidden">

											<button type="button" onclick="toggleTag(this, 'tag_jungso')" class="px-3.5 py-1.5 text-xs rounded-full border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition font-medium">중소사업장</button>
											<input type="checkbox" id="tag_jungso" name="searchMultiIemArrayHashTag" value="중소사업장" class="hidden">

											<button type="button" onclick="toggleTag(this, 'tag_jaehae')" class="px-3.5 py-1.5 text-xs rounded-full border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition font-medium">재해예방</button>
											<input type="checkbox" id="tag_jaehae" name="searchMultiIemArrayHashTag" value="재해예방" class="hidden">

